                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Status 200\r",
                  "pm.test(\"Status code es 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// Tiempo de respuesta\r",
                  "pm.test(\"Tiempo menor a 1000ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
                  "});\r",
                  "\r",
                  "// Contrato JSON completo\r",
                  "pm.test(\"Producto tiene todos los campos requeridos\", function () {\r",
                  "    const product = pm.response.json();\r",
                  "    pm.expect(product).to.have.property(\"id\");\r",
                  "    pm.expect(product).to.have.property(\"title\");\r",
                  "    pm.expect(product).to.have.property(\"price\");\r",
                  "    pm.expect(product).to.have.property(\"description\");\r",
                  "    pm.expect(product).to.have.property(\"category\");\r",
                  "    pm.expect(product).to.have.property(\"image\");\r",
                  "});\r",
                  "\r",
                  "// El producto existe (tiene ID)\r",
                  "pm.test(\"El producto está en existencia\", function () {\r",
                  "    const product = pm.response.json();\r",
                  "    pm.expect(product.id).to.exist;\r",
                  "});"
